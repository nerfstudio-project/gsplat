set -euo pipefail

# ---- do not edit the line below ----
# GSPLAT PRE-COMMIT HOOK
# ------------------------------------

# Run the committing worktree's formatter (git runs the hook there), passing
# only options it advertises in --help so this keeps working against an older or
# garbled format-code.sh.
formatter="$(git rev-parse --show-toplevel)/lint/format-code.sh"

# A flag counts as advertised only when it heads its own entry in --help's
# options list -- an indented line (options are indented; the synopsis and prose
# start at column 0), the flag, then a space. Matching a bare mention would
# misread a flag named in another option's description or a prose paragraph.
advertises() { grep -qE "^[[:space:]]+${1}([[:space:]]|\$)" <<<"${help}"; }

if [[ -x "${formatter}" ]]; then
    help="$("${formatter}" --help 2>/dev/null || true)"
    if advertises --precommit; then
        # Current format-code.sh: format and re-stage the staged content.
        # Known limit: for a pathspec commit (git commit -- <path>) git commits
        # from a temporary index this hook cannot reach, so the real index can
        # keep the pre-format content; the next hook run normalizes it.
        exec "${formatter}" --precommit
    elif advertises --check && advertises --full; then
        # Older format-code.sh without --precommit: whole-tree check instead.
        exec "${formatter}" --check --full
    else
        # Not a format-code.sh we recognize.
        echo "WARNING: this worktree's lint/format-code.sh appears invalid; this commit was" >&2
        echo "         not formatted." >&2
    fi
else
    # No formatter to run (e.g. a checkout predating it).
    echo "WARNING: no runnable lint/format-code.sh in this worktree; this commit was" >&2
    echo "         not formatted." >&2
fi
